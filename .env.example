# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Meta (Facebook) ──────────────────────────────────────
# Token de acceso con permiso ads_read (largo plazo recomendado)
FACEBOOK_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx

# App ID y App Secret (necesarios para renovar el token a 60 días)
# Encontralos en: Meta for Developers → Mis aplicaciones → Configuración → Básica
META_APP_ID=123456789012345
META_APP_SECRET=abcdef0123456789abcdef0123456789

# ── Páginas a monitorear ─────────────────────────────────
# IDs de Facebook Pages separados por coma. Encontralos en la URL de la página
# o en https://www.facebook.com/ads/library/
SEARCH_PAGE_IDS=125816360773347

# ── Opcionales ───────────────────────────────────────────
# Versión de la Graph API (default: v19.0)
# META_GRAPH_VERSION=v19.0

# Marcar como inactivos los anuncios que ya no aparecen en la API (default: true)
# MARK_STALE_INACTIVE=true

# Reintentos máximos ante rate-limiting (default: 5)
# META_MAX_RETRIES=5

# Backoff inicial en segundos ante rate-limiting (default: 2.0)
# META_INITIAL_BACKOFF_SECONDS=2.0

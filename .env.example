# ─── Supabase ───────────────────────────────────────────────
# URL del proyecto Supabase (Settings -> API -> Project URL)
SUPABASE_URL=https://xxxx.supabase.co
# Key de servicio (Settings -> API -> service_role secret)
SUPABASE_KEY=eyJ...

# ─── Apify ──────────────────────────────────────────────────
# Token de API de Apify (https://console.apify.com/account#/integrations)
APIFY_TOKEN=apify_api_xxxx
# Actor a usar (default: curious_coder/facebook-ads-library-scraper)
# APIFY_ACTOR_ID=curious_coder/facebook-ads-library-scraper
# Máximo de anuncios a extraer por competidor (default: 200)
# APIFY_MAX_ITEMS=200

# ─── Gemini (análisis IA) ──────────────────────────────────
# API key de Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...
